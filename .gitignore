# Skip specific directories
/pytest/
/venv/
/.venv/
/.claude/
/.pytest_cache/
/data/
/dev-documentation/
/bench/

# Ignore Rust build artifacts (keep wheels for distribution)
/target/
!/target/wheels/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Compiled extension modules (built by maturin develop)
*.so
*.pyd

# IDE and editor settings
.vscode/

# Performance baselines (dev artifacts)
/baselines/
/.benchmarks/

# Hypothesis database (property-based testing cache)
/.hypothesis/

# Coverage data
.coverage
coverage.xml

# Generated graph files
*.kgl

# Sphinx docs build output
docs/_build/
docs/autoapi/

# macOS system files
.DS_Store
uv.lock
